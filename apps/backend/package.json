{
  "name": "@smart-inventory/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env ./src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env ./dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx --env-file=.env scripts/seed-admin.ts",
    "seed:categories": "tsx --env-file=.env scripts/seed-categories.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.7",
    "@types/cookie-parser": "^1.4.10",
    "bcrypt": "^6.0.0",
    "cloudinary": "^1.41.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.18.0",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pino": "^10.1.0",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.2.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  }
}
